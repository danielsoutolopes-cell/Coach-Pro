{
  "expo": {
    "name": "Coach Pro",
    "slug": "Coach-Pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "procoach-os",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A" 
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.procoachos.app",
      "backgroundColor": "#0A0A0A",
      "versionCode": 11
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF5F00",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "56bc50d8-fc7d-4cc5-96a6-2d19d3ffb0eb"
      }
    },
    "owner": "danielsoutolopes"
  }
}
